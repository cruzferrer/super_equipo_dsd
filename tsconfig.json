{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["jest", "node"],
    "typeRoots": [
      "./node_modules/@types",
      "./epic_simulador/node_modules/@types"
    ],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./epic_simulador/dist",
    "rootDir": "./epic_editor"
  },
  "include": ["epic_editor/**/*"],
  "exclude": ["node_modules", "epic_motor", "epic_simulador"]
}